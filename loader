local function log_status(msg)
    log("[AutoFarm] " .. msg)
end

local function get_current_row()
    return bot:pos().tile_y
end

local function count_seeds()
    local inv   = bot:get_inventory()
    local total = 0
    for _, item in ipairs(inv) do
        if item.id == CONFIG.TARGET_ID and item.inventory_type == 2 then
            total = total + item.amount
        end
    end
    return total
end

local function get_inventory_count()
    local inv        = bot:get_inventory()
    local seedCount  = 0
    local blockCount = 0
    for _, item in ipairs(inv) do
        if item.id == CONFIG.TARGET_ID then
            if item.inventory_type == 2 then
                seedCount = seedCount + item.amount
            elseif item.inventory_type == 0 then
                blockCount = blockCount + item.amount
            end
        end
    end
    return seedCount, blockCount
end

local function get_item_inventory_type(itemId)
    local inv = bot:get_inventory()
    for _, item in ipairs(inv) do
        if item.id == itemId then
            return item.inventory_type, item.amount
        end
    end
    return nil, 0
end

local function count_ready_seeds_in_row(row)
    local count = 0
    local w     = bot:get_world()
    for _, seed in ipairs(w.seeds) do
        if seed.ready and seed.block_type == CONFIG.TARGET_ID and seed.y == row then
            count = count + 1
        end
    end
    return count
end


local function count_all_ready_seeds()
    local base  = get_current_row()
    local total = 0
    for i = 0, CONFIG.ROW_TOTAL - 1 do
        total = total + count_ready_seeds_in_row(base + i)
    end
    return total
end

local function check_and_place_lock()
    log_status("🔒 Cek apakah world sudah di-lock...")

    local w = bot:get_world()

    -- Cek apakah sudah ada lock (ID 2212 atau 413) di world tiles
    for _, tile in ipairs(w.tiles or {}) do
        if LOCK_IDS[tile.fg] or LOCK_IDS[tile.bg] then
            log_status("✅ World sudah di-lock (ID=" .. (tile.fg ~= 0 and tile.fg or tile.bg) .. "), skip pasang lock.")
            return
        end
    end

    log_status("⚠️ World BELUM di-lock! Coba pasang lock...")

    -- Cari lock di inventori (prioritas World Lock dulu, lalu Newbie Lock)
    local lockIdToPlace = nil
    local inv = bot:get_inventory()
    for _, item in ipairs(inv) do
        if item.id == 413 then
            lockIdToPlace = 413
            break
        end
    end
    if not lockIdToPlace then
        for _, item in ipairs(inv) do
            if item.id == 2212 then
                lockIdToPlace = 2212
                break
            end
        end
    end

    -- Posisi bot saat masuk (entrance)
    local pos = bot:pos()
    local botX = pos.tile_x
    local botY = pos.tile_y

local targetX = botX
local targetY = botY - 1

local entranceTile = bot:get_tile(targetX, targetY)

-- Jika di bawah entrance sudah ada lock, skip seluruh proses
if entranceTile and LOCK_IDS[entranceTile.fg] then
    log_status("✅ Entrance sudah berisi lock ID=" .. entranceTile.fg .. ", skip break & place lock.")
    return
end

log_status(string.format(
    "🔨 Break block di bawah entrance (%d, %d)...", targetX, targetY
))

for i = 1, CONFIG.HIT_BLOCK do
    bot:hit_block(0, -1)
    sleep_ms(CONFIG.DELAY_HARVEST)

    local check = bot:get_tile(targetX, targetY)

    if check and check.fg == 0 then
        log_status("✅ Tile bawah entrance berhasil di-clear!")
        break
    end
end

    if not lockIdToPlace then
        log_status("⚠️ Tidak ada lock di inventori! Mencoba beli WorldLock...")
        bot:buy_pack("WorldLock")
        sleep_ms(500)
        bot:buy_pack("WorldLock")
        sleep_ms(500)
        bot:buy_pack("WorldLock")
        
        sleep_ms(15000)

        -- Cek ulang inventori setelah beli
        local inv2 = bot:get_inventory()
        for _, item in ipairs(inv2) do
            if item.id == 413 then
                lockIdToPlace = 413
                break
            end
        end
        if not lockIdToPlace then
            for _, item in ipairs(inv2) do
                if item.id == 2212 then
                    lockIdToPlace = 2212
                    break
                end
            end
        end

        if not lockIdToPlace then
            log_status("❌ Beli WorldLock gagal atau tidak diterima di inventori, skip pasang lock.")
            return
        end
        log_status("✅ WorldLock berhasil dibeli! Lanjut pasang lock...")
    end

    -- Place lock di tile bawah entrance
    sleep_ms(300)
    local tile = bot:get_tile(targetX, targetY)
    if tile and tile.fg == 0 then
        bot:place_block(0, -1, lockIdToPlace)
        sleep_ms(500)
        log_status("✅ Lock ID=" .. lockIdToPlace .. " berhasil dipasang di (" .. targetX .. "," .. targetY .. ")!")
    else
        log_status("⚠️ Tile (" .. targetX .. "," .. targetY .. ") masih blocked, lock tidak dipasang.")
    end
end
-- ============================================================
--              BREAK BLOCKING BLOCKS (HELPER BARU)
-- ============================================================

local function break_blocking_blocks(tx, ty)
    local tile = bot:get_tile(tx, ty)
    if not tile then return end

    if tile.fg ~= 0 then

       -- ✅ SKIP hanya jika fg=37 DAN seed di tile ini adalah TARGET_ID
        if tile.fg == 37 then
            local w_check = bot:get_world()
            local isTargetTree = false
            for _, seed in ipairs(w_check.seeds) do
                if seed.x == tx and seed.y == ty and seed.block_type == CONFIG.TARGET_ID then
                    isTargetTree = true
                    break
                end
            end
            if isTargetTree then
                log_status("🌳 Tree TARGET_ID di (" .. tx .. "," .. ty .. "), skip break.")
                return
            else
                log_status("🪓 fg=37 tapi bukan TARGET_ID di (" .. tx .. "," .. ty .. "), lanjut break...")
            end
        end

        -- Skip jika ID ada di static blacklist
        if BLOCK_BLACKLIST[tile.fg] then
            log_status("🚫 Block fg ID=" .. tile.fg .. " di (" .. tx .. "," .. ty .. ") di-BLACKLIST, skip break.")
            return
        end

        -- Handler khusus water (ID 16) pakai owBK
        if tile.fg == WATER_ID then
            log_status("💧 Water block di (" .. tx .. "," .. ty .. "), kirim owBK packet...")
            for i = 1, CONFIG.HIT_BLOCK do
                bot:send("owBK", { tx, ty })
                sleep_ms(CONFIG.DELAY_HARVEST)
                local check = bot:get_tile(tx, ty)
                if check and check.fg == 0 then
                    log_status("✅ Water di (" .. tx .. "," .. ty .. ") berhasil dihapus!")
                    break
                end
            end
            local final = bot:get_tile(tx, ty)
            if final and final.fg == WATER_ID then
                log_status("⚠️ Water masih ada setelah " .. CONFIG.HIT_BLOCK .. " hit di (" .. tx .. "," .. ty .. ")")
            end
            return
        end

        -- Block biasa, hit normal
        log_status("⚠️ Block fg menghalangi di (" .. tx .. "," .. ty .. "), break...")

        -- Pastikan bot dekat dulu sebelum hit (max 2 tile)
        local dist = math.abs(tx - bot:pos().tile_x) + math.abs(ty - bot:pos().tile_y)
        if dist > 2 then
            log_status("🚶 Terlalu jauh (" .. dist .. " tile), jalan dulu ke (" .. tx .. "," .. ty .. ")...")
            pcall(function() bot:find_path(tx, ty) end)
            sleep_ms(1400)
        end

        local dx = tx - bot:pos().tile_x
        local dy = ty - bot:pos().tile_y
        for i = 1, CONFIG.HIT_BLOCK do
            bot:hit_block(dx, dy)
            sleep_ms(CONFIG.DELAY_HARVEST)
            local check = bot:get_tile(tx, ty)
            if check and check.fg == 0 then
                log_status("✅ Block fg di (" .. tx .. "," .. ty .. ") berhasil dihancurkan!")
                break
            end
        end
        local final = bot:get_tile(tx, ty)
        if final and final.fg ~= 0 then
            log_status("⚠️ Block fg masih ada setelah " .. CONFIG.HIT_BLOCK .. " hit di (" .. tx .. "," .. ty .. ")")
        end
    end
end

-- Versi offset (dari posisi bot sekarang)
local function break_blocking_blocks_offset(dx, dy)
    local pos = bot:pos()
    break_blocking_blocks(pos.tile_x + dx, pos.tile_y + dy)
end

-- ============================================================
--                      RECONNECT HELPER
-- ============================================================

local function ensure_in_world(targetWorld, label)
    local maxTry = 5
    for attempt = 1, maxTry do
        if bot:state() == "InWorld" then return true end
        log_status("⚠️ [" .. label .. "] Tidak di world (attempt " .. attempt .. "/" .. maxTry .. "), reconnect...")
        if bot:state() == "Failed" or bot:state() == "Disconnected" then
            bot:connect()
            sleep_ms(3000)
        end
        bot:warp(targetWorld)
        sleep_ms(4500)
    end
    log_status("❌ [" .. label .. "] Gagal masuk world setelah " .. maxTry .. " attempt.")
    return false
end

