            log_status(string.format(
                "🚨 SEED THRESHOLD! Seed: %d >= %d → Stop semua, warp save world!",
                seedCount, CONFIG.SEED_THRESHOLD
            ))
            check_seed_threshold()

        -- ===== PRIORITAS 2: BELI PACK =====
        elseif CONFIG.BUY_PACK_ENABLED and currentGems >= CONFIG.GEM_THRESHOLD then
            log_status("💎 Gems " .. currentGems .. " >= " .. CONFIG.GEM_THRESHOLD .. " → Beli pack!")
            do_buy_pack()

        -- ===== PRIORITAS 3: COLLECT MOVE (awal) =====
        else
            local base  = get_current_row()
            local ready = count_all_ready_seeds()

            log_status(string.format(
                "💎 Gems: %d | Ready: %d (%d row) | Block: %d | Seed: %d / %d (threshold)",
                currentGems, ready, CONFIG.ROW_TOTAL, blockCount, seedCount, CONFIG.SEED_THRESHOLD
            ))

            -- ===== BLOCK BANYAK → PNB DI WORLD RANDOM =====
            if blockCount >= CONFIG.BLOCK_THRESHOLD then
                log_status(string.format(
                    "📦 Block: %d >= %d → Mulai PNB di world random!",
                    blockCount, CONFIG.BLOCK_THRESHOLD
                ))
                -- Hanya generate world baru + reset siklus jika belum ada sesi PNB aktif
                -- (jika isInPnbMode=true berarti baru rejoin, siklus harus dilanjutkan)
                if not isInPnbMode then
                    pnbRandomWorld = generate_random_world()
                    pnbCycleCount  = 0
                    pnbNeedCollect = false
                    log_status("🎲 Sesi PNB baru → world: " .. pnbRandomWorld)
                else
                    log_status(string.format(
                        "🔁 Lanjut sesi PNB yang sama → world: %s | siklus: %d/%d",
                        pnbRandomWorld, pnbCycleCount, CONFIG.PNB_MAX_CYCLES
                    ))
                end
                do_pnb_in_random_world()

elseif ready > 0 and blockCount < CONFIG.BLOCK_THRESHOLD then
                log_status("🌳 " .. ready .. " seed ready → tunggu semua row, lalu harvest...")
                wait_until_rows_ready()
                do_harvest_and_plant()

            elseif seedCount > 5 then
                do_plant_row()
            end
        end
    end
    sleep_ms(200)
end
