--                      TILE HELPER
-- ============================================================

local function clear_tile_if_blocked(tx, ty)
    local tile = bot:get_tile(tx, ty)
    if tile and tile.fg ~= 0 then
        log_status("⚠️ Tile (" .. tx .. "," .. ty .. ") blocked, menghancurkan dulu...")
        local dx = tx - bot:pos().tile_x
        local dy = ty - bot:pos().tile_y
        for i = 1, CONFIG.HIT_BLOCK do
            bot:hit_block(dx, dy)
            sleep_ms(CONFIG.DELAY_HARVEST)
            local check = bot:get_tile(tx, ty)
            if check and check.fg == 0 then
                log_status("✅ Tile (" .. tx .. "," .. ty .. ") berhasil dihancurkan!")
                break
            end
        end
        local final = bot:get_tile(tx, ty)
        if final and final.fg ~= 0 then
            log_status("⚠️ Tile masih blocked setelah " .. CONFIG.HIT_BLOCK .. " hit, skip.")
        end
    end
end

local function safe_find_path(tx, ty)
    local ok = pcall(function() bot:find_path(tx, ty) end)
    if not ok then
        log_status("⚠️ find_path blocked ke (" .. tx .. "," .. ty .. "), mencoba hancurkan block...")
        clear_tile_if_blocked(tx, ty)
        sleep_ms(300)
        local ok2 = pcall(function() bot:find_path(tx, ty) end)
        if not ok2 then
            log_status("❌ find_path masih gagal ke (" .. tx .. "," .. ty .. "), skip.")
        end
    end
    sleep_ms(1400)
end

-- ============================================================
--                     WAIT UNTIL READY
-- ============================================================

local function wait_until_rows_ready()
    local CHECK_INTERVAL = 5000
    local BUFFER_MS      = 500
    local base           = get_current_row()

    while true do
        local w            = bot:get_world()
        local totalSeeds   = 0
        local readyCount   = 0
        local maxRemaining = 0

        for _, seed in ipairs(w.seeds) do
            if seed.block_type == CONFIG.TARGET_ID then
                for i = 0, CONFIG.ROW_TOTAL - 1 do
                    if seed.y == base + i then
                        totalSeeds = totalSeeds + 1
                        if seed.ready then
                            readyCount = readyCount + 1
                        else
                            if seed.remaining_ms and seed.remaining_ms > maxRemaining then
                                maxRemaining = seed.remaining_ms
                            end
                        end
                        break
                    end
                end
            end
        end

        if totalSeeds == 0 then
            log_status("⚠️ Tidak ada seed di " .. CONFIG.ROW_TOTAL .. " row, lanjut...")
            return
        end

        if readyCount >= totalSeeds then
            log_status(string.format("✅ Semua seed sudah ready! (%d/%d)", readyCount, totalSeeds))
            return
        end

        log_status(string.format(
            "⏳ Menunggu... Ready: %d/%d | Terlama: %.1f detik (~%d menit)",
            readyCount, totalSeeds,
            maxRemaining / 1000,
            math.ceil(maxRemaining / 60000)
        ))

        local elapsed = 0
        local target  = maxRemaining + BUFFER_MS
        while elapsed < target do
            sleep_ms(CHECK_INTERVAL)
            elapsed = elapsed + CHECK_INTERVAL

            local w2          = bot:get_world()
            local stillWaiting = false
            local maxLeft      = 0
            for _, seed in ipairs(w2.seeds) do
                if seed.block_type == CONFIG.TARGET_ID then
                    for i = 0, CONFIG.ROW_TOTAL - 1 do
                        if seed.y == base + i and not seed.ready then
                            stillWaiting = true
                            if seed.remaining_ms and seed.remaining_ms > maxLeft then
                                maxLeft = seed.remaining_ms
                            end
                            break
                        end
                    end
                end
            end

            if not stillWaiting then
                log_status("✅ Semua seed sudah ready (early detect)!")
                return
            end
            log_status(string.format("⏳ Masih menunggu... sisa ~%.1f detik", maxLeft / 1000))
        end
    end
end

