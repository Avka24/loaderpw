--                       WORLD EVENTS
-- ============================================================

bot:on(events.JOINED_WORLD, function(data)
    local worldName = data.world or ""
    log_status("✅ Joined world: " .. worldName)
    sleep_ms(2000)
    
    needCollect = true
    isBusy      = false

    -- Jika join ke PNB world (reconnect ditangani inline oleh pnb_ensure_connected)
    if isInPnbMode and pnbRandomWorld and
       string.upper(worldName) == string.upper(pnbRandomWorld) then
        log_status("🔄 Rejoined ke PNB world: " .. worldName .. " → tandai untuk collect ulang dari awal.")
        pnbJustRejoined = true
        knownPlayers = buildPlayerList()
        return
    end

    -- Jika join ke farm world
    if string.upper(worldName) == string.upper(CONFIG.FARM_WORLD) then
        local currentPlayers = buildPlayerList()
        log_status("🛡️ Scan " .. (function() local c=0; for _ in pairs(currentPlayers) do c=c+1 end; return c end)() .. " pemain yang sudah ada di world...")

        local pendingBan = {}
        for userId, player in pairs(currentPlayers) do
            local username = player.username or "UNKNOWN"
            if isWhitelisted(username) then
                log_status("✅ WHITELIST OK → " .. username)
            else
                log_status("⏳ NON-WHITELIST (ditunda) → akan di-ban setelah place lock: " .. username)
                table.insert(pendingBan, { userId = userId, username = username })
            end
        end

        knownPlayers = buildPlayerList()
        sleep_ms(1000)

        check_and_place_lock()

        for _, p in ipairs(pendingBan) do
            log_status("🚨 NON-WHITELIST → BAN (setelah lock): " .. p.username)
            bot:world_ban(p.userId)
            sleep_ms(300)
        end

        knownPlayers = buildPlayerList()
        sleep_ms(1000)

        check_and_place_lock()
    else
        knownPlayers = buildPlayerList()
    end
end)

