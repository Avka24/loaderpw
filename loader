local function do_collect_move()
    isBusy = true

    local originX = bot:pos().tile_x
    local originY = bot:pos().tile_y
    pnbOriginX    = originX
    pnbOriginY    = originY

    log_status("📦 Collect move dari (" .. originX .. "," .. originY .. ")...")

    local targetTiles = {}
    for _, spot in ipairs(CONFIG.PNB_SPOTS) do
        table.insert(targetTiles, {
            x = originX + spot.dx,
            y = originY + spot.dy,
        })
    end

    for _, t in ipairs(targetTiles) do
        log_status("  → find_path ke (" .. t.x .. ", " .. t.y .. ")")
        safe_find_path(t.x, t.y)
        sleep_ms(CONFIG.COLLECT_MOVE_DELAY)
    end

    log_status("🔙 Kembali ke origin (" .. originX .. "," .. originY .. ")")
    safe_find_path(originX, originY)
    sleep_ms(400)

    log_status("✅ Collect selesai.")
    needCollect    = false
    pnbNeedCollect = false
    isBusy         = false
end

-- ============================================================
--                       BUY PACK
-- ============================================================

local function do_buy_pack()
    isBusy = true
    local gems = bot.gems
    log_status("💎 Gems: " .. gems .. " (threshold: " .. CONFIG.GEM_THRESHOLD .. ")")

    if gems < CONFIG.GEM_THRESHOLD then
        isBusy = false
        return
    end

    local totalCanBuy = math.floor((gems - CONFIG.GEM_STOP) / CONFIG.PACK_PRICE)
    if totalCanBuy <= 0 then
        log_status("⚠️ Tidak cukup gems untuk beli pack.")
        isBusy = false
        return
    end

    log_status("🛒 Mulai beli " .. totalCanBuy .. "x pack: " .. CONFIG.BUY_PACK_ID)

    -- PHASE 1: BELI PACK
    local buyCount = 0
    local i        = 1
    while i <= totalCanBuy do
        if bot:state() ~= "InWorld" then
            log_status("⚠️ Disconnect saat beli pack! Reconnect...")
            local ok = ensure_in_world(CONFIG.FARM_WORLD, "BuyPack-Reconnect")
            if not ok then
                log_status("❌ Gagal reconnect. Abort beli pack.")
                isBusy = false
                return
            end
            local newGems   = bot.gems
            local remaining = math.floor((newGems - CONFIG.GEM_STOP) / CONFIG.PACK_PRICE)
            if remaining <= 0 then break end
            totalCanBuy = buyCount + remaining
        end
        bot:buy_pack(CONFIG.BUY_PACK_ID)
        sleep_ms(2000)
        buyCount = buyCount + 1
        log_status("✅ Pack ke-" .. buyCount .. "/" .. totalCanBuy .. " | Gems sisa: " .. bot.gems)
        i = i + 1
    end

    log_status("🏁 Selesai beli pack. Total: " .. buyCount .. "x | Gems: " .. bot.gems)

    -- PHASE 2: WARP KE SAVE WORLD
    isInSaveWorld = true
    log_status("📦 Warp ke save world...")
    bot:warp(CONFIG.SAVE_WORLD)
    sleep_ms(4500)

    if bot:state() ~= "InWorld" then
        local ok = ensure_in_world(CONFIG.SAVE_WORLD, "BuyPack-SaveWorld")
        if not ok then
            isInSaveWorld = false
            bot:warp(CONFIG.FARM_WORLD)
            sleep_ms(4500)
            isBusy = false
            return
        end
    end

    -- PHASE 3: DROP ITEM
    local dropCfg  = CONFIG.BUY_PACK_DROP
    local maxRetry = 3
    local dropDone = false

    for attempt = 1, maxRetry do
        if bot:state() ~= "InWorld" then
            local ok = ensure_in_world(CONFIG.SAVE_WORLD, "BuyPack-Drop")
            if not ok then break end
        end
        if bot:state() == "InWorld" then
            local invType, amount = get_item_inventory_type(dropCfg.id)
            if invType ~= nil and amount > 0 then
                log_status("📍 Drop item ID=" .. dropCfg.id .. " → (" .. dropCfg.x .. "," .. dropCfg.y .. ")")
                safe_find_path(dropCfg.x, dropCfg.y)
                sleep_ms(500)
                bot:drop(dropCfg.id, amount, invType)
                sleep_ms(800)
                local _, amountAfter = get_item_inventory_type(dropCfg.id)
                if amountAfter < amount then
                    log_status("✅ Drop berhasil! x" .. (amount - amountAfter))
                    dropDone = true
                    break
                else
                    log_status("⚠️ Drop gagal, retry " .. (attempt + 1) .. "...")
                    sleep_ms(1500)
                end
            else
                log_status("⚠️ Item ID=" .. dropCfg.id .. " tidak ada di inventori, skip.")
                dropDone = true
                break
            end
        end
    end

    if not dropDone then
        log_status("❌ Drop gagal setelah " .. maxRetry .. " attempt.")
    end

    -- PHASE 4: KEMBALI KE FARM
    sleep_ms(1000)
    isInSaveWorld = false
    log_status("🔙 Kembali ke farm world...")
    bot:warp(CONFIG.FARM_WORLD)
    sleep_ms(4500)

    if bot:state() ~= "InWorld" then
        ensure_in_world(CONFIG.FARM_WORLD, "BuyPack-ReturnFarm")
    end

    log_status("💎 Gems setelah buy pack: " .. bot.gems)
    needCollect = true
    isBusy      = false
end

-- ============================================================
--                    SAVE WORLD + DROP
-- ============================================================

local function go_to_save_and_drop()
    isInSaveWorld = true
    log_status("💾 Masuk save world: " .. CONFIG.SAVE_WORLD)
    bot:warp(CONFIG.SAVE_WORLD)
    sleep_ms(4000)

    if bot:state() ~= "InWorld" then
        local ok = ensure_in_world(CONFIG.SAVE_WORLD, "SaveAndDrop")
        if not ok then
            isInSaveWorld = false
            bot:warp(CONFIG.FARM_WORLD)
            sleep_ms(4500)
            needCollect = true
            return
        end
    end

    -- DROP SEED (sisakan KEEP_SEED_AMOUNT)
    local inv = bot:get_inventory()
    for _, item in ipairs(inv) do
        if item.id == CONFIG.TARGET_ID and item.inventory_type == 2 then
            local keepAmount = CONFIG.KEEP_SEED_AMOUNT
            if item.amount > keepAmount then
                local dropAmount = item.amount - keepAmount
                bot:drop(item.id, dropAmount, 2)
                sleep_ms(600)
                log_status("✅ Drop " .. dropAmount .. " seed | Keep: " .. keepAmount)
            else
                log_status("⚠️ Seed hanya " .. item.amount .. " (< keep " .. keepAmount .. "), skip drop seed.")
            end
        end
    end

    sleep_ms(800)

    -- DROP ITEM_DROP SEMUA (tidak ada keep)
    for _, dropCfg in ipairs(CONFIG.ITEM_DROP) do
        local itemId  = dropCfg.id
        local targetX = dropCfg.x
        local targetY = dropCfg.y
        local invType, amount = get_item_inventory_type(itemId)
        if invType ~= nil and amount > 0 then
            log_status("📍 Drop item ID=" .. itemId .. " x" .. amount .. " → (" .. targetX .. "," .. targetY .. ")")
            safe_find_path(targetX, targetY)
            sleep_ms(500)
            bot:drop(itemId, amount, invType)
            sleep_ms(600)
            log_status("✅ Drop ID=" .. itemId .. " x" .. amount)
        else
            log_status("⚠️ Item ID=" .. itemId .. " tidak ada di inventori, skip.")
        end
    end

    sleep_ms(1500)
    isInSaveWorld = false
    log_status("🔙 Kembali ke farm world...")
    bot:warp(CONFIG.FARM_WORLD)
    sleep_ms(3500)

    needCollect = true
end

-- ============================================================
--             CEK SEED THRESHOLD → STOP & DROP
