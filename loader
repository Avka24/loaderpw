local function generate_random_world()
    -- Diawali huruf, total 7 atau 8 karakter, campuran huruf dan angka
    local letters = "ABCDEFGHIJKLMNOPQRSTUVWXYZ"
    local alphanums = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789"

    -- Tentukan panjang: 7 atau 8
    local length = 7 + math.random(0, 1)

    local name = ""
    -- Karakter pertama: huruf
    local firstIdx = math.random(1, #letters)
    name = name .. string.sub(letters, firstIdx, firstIdx)

    -- Karakter sisanya: huruf atau angka, pastikan ada minimal 1 angka
    local hasNumber = false
    for i = 2, length do
        local idx = math.random(1, #alphanums)
        local char = string.sub(alphanums, idx, idx)
        name = name .. char
        if char >= "0" and char <= "9" then
            hasNumber = true
        end
    end

    -- Jika belum ada angka, ganti salah satu posisi (2 sampai length) dengan angka
    if not hasNumber then
        local replacePos = math.random(2, length)
        local digits = "0123456789"
        local digitIdx = math.random(1, #digits)
        local digit = string.sub(digits, digitIdx, digitIdx)
        name = string.sub(name, 1, replacePos - 1) .. digit .. string.sub(name, replacePos + 1)
    end

    return name
end

-- ============================================================
