-- ============================================================
--                      AUTO RECONNECT EVENT
-- ============================================================

bot:on(events.STATE_CHANGED, function(data)
    local state = data.state
    if state == "MenuIdle" or state == "Failed" then
        local targetWorld

        -- Jika sedang PNB mode, inline handler di do_pnb_in_random_world yang handle reconnect
        if isInPnbMode and pnbRandomWorld then
            targetWorld = pnbRandomWorld
            log_status("⚠️ Disconnect saat PNB Mode → inline handler akan rejoin ke: " .. targetWorld)
        elseif isInSaveWorld then
            targetWorld = CONFIG.SAVE_WORLD
            log_status("⚠️ Disconnect: " .. state .. " → Rejoining save world: " .. targetWorld)
        else
            targetWorld = CONFIG.FARM_WORLD
            log_status("⚠️ Disconnect: " .. state .. " → Rejoining farm world: " .. targetWorld)
        end

        needCollect = true
        isBusy      = false
        sleep_ms(1500)

        if state == "MenuIdle" then
            bot:warp(targetWorld)
        elseif state == "Failed" then
            bot:connect()
            sleep_ms(2500)
            if bot:state() == "MenuIdle" then
                bot:warp(targetWorld)
            end
        end
    end
end)

