local function check_seed_threshold()
    local seedCount = count_seeds()
    if seedCount >= CONFIG.SEED_THRESHOLD then
        log_status(string.format(
            "🚨 SEED THRESHOLD TERCAPAI! Seed: %d >= %d → Stop semua aktivitas, warp ke save world!",
            seedCount, CONFIG.SEED_THRESHOLD
        ))
        isBusy = true
        go_to_save_and_drop()
        isBusy = false
        return true
    end
    return false
end

-- ============================================================
--                  HARVEST + PLANT (MULTI ROW SNAKE)
-- ============================================================

local function do_harvest_and_plant()
    isBusy = true

    -- Simpan posisi awal SEKALI di sini, tidak boleh berubah
    local start_pos = bot:pos()
    local base_row  = start_pos.tile_y   -- y30 (posisi awal bot)
    local start_x   = start_pos.tile_x
    local w         = bot:get_world()
    local max_x     = w.width - 1

    -- Validasi row range: hanya base_row sampai base_row + ROW_TOTAL - 1
    local row_min = base_row
    local row_max = base_row + CONFIG.ROW_TOTAL - 1  -- y30 + 3 - 1 = y32

    local harvested = 0
    local planted   = 0

    log_status(string.format(
        "🚜 Mulai harvest. base_row=%d, row_range=%d~%d, start_x=%d",
        base_row, row_min, row_max, start_x
    ))

    local function has_tree_at(x, row)
        local w_cur = bot:get_world()
        for _, seed in ipairs(w_cur.seeds) do
            if seed.x == x and seed.y == row and seed.block_type == CONFIG.TARGET_ID then
                return true
            end
        end
        return false
    end

    local function process_tile(x, row)
        -- Validasi: jangan proses di luar range row yang diizinkan
        if row < row_min or row > row_max then
            log_status("⛔ Row Y=" .. row .. " di luar range (" .. row_min .. "~" .. row_max .. "), skip!")
            return
        end

        -- 1. Hancurkan block yang menghalangi di tile ini
        break_blocking_blocks(x, row)

        local w_cur = bot:get_world()

        -- 2. Cek apakah ada seed ready
        for _, seed in ipairs(w_cur.seeds) do
            if seed.x == x and seed.y == row and seed.ready and seed.block_type == CONFIG.TARGET_ID then
                bot:hit_block(0, 0)
                sleep_ms(CONFIG.DELAY_HARVEST)
                harvested = harvested + 1
                log_status("✅ Harvest X=" .. x .. " Y=" .. row)

                break_blocking_blocks(x, row)

                if count_seeds() > 0 then
                    bot:plant(x, row, CONFIG.TARGET_ID)
                    sleep_ms(CONFIG.DELAY_PLANT)
                    planted = planted + 1
                    log_status("🌱 Replant X=" .. x .. " Y=" .. row)
                end
                return
            end
        end

        -- 3. Tile kosong (tidak ada pohon sama sekali) → plant
        if not has_tree_at(x, row) then
            break_blocking_blocks(x, row)
            local tile = bot:get_tile(x, row)
            if tile and tile.fg == 0 and count_seeds() > 0 then
                bot:plant(x, row, CONFIG.TARGET_ID)
                sleep_ms(CONFIG.DELAY_PLANT)
                planted = planted + 1
                log_status("🌱 Tile kosong, plant X=" .. x .. " Y=" .. row)
            end
        end
    end

    -- ===== LOOP SETIAP ROW — PAKAI row_min s/d row_max =====
    for i = 0, CONFIG.ROW_TOTAL - 1 do
        local row     = base_row + i      -- y30, y31, y32 (tidak pernah y33+)
        local go_left = (i % 2 == 1)

        -- Double-check: pastikan row tidak melebihi row_max
        if row > row_max then
            log_status("⛔ Row Y=" .. row .. " melebihi row_max=" .. row_max .. ", stop loop!")
            break
        end

        local ready = count_ready_seeds_in_row(row)
        log_status(string.format(
            "📍 [Row %d/%d] Y=%d | ready=%d | arah=%s",
            i+1, CONFIG.ROW_TOTAL, row, ready,
            go_left and "kanan→kiri" or "kiri→kanan"
        ))

        -- Pindah ke awal row ini
        local first_x = go_left and max_x or start_x
        break_blocking_blocks(first_x, row)
        safe_find_path(first_x, row)

        -- Tunggu bot sampai di row yang benar
        local attempts = 0
        while bot:pos().tile_y ~= row and attempts < 5 do
            log_status("⚠️ Bot belum di Y=" .. row .. " (sekarang di Y=" .. bot:pos().tile_y .. "), retry...")
            sleep_ms(800)
            break_blocking_blocks(first_x, row)
            safe_find_path(first_x, row)
            attempts = attempts + 1
        end

        -- Jika bot tidak berhasil pindah ke row yang benar, skip row ini
        if bot:pos().tile_y ~= row then
            log_status("❌ Gagal pindah ke Y=" .. row .. " (bot di Y=" .. bot:pos().tile_y .. "), skip row ini.")
            goto continue
        end

        -- ===== JALAN TILE PER TILE DI ROW INI =====
        if not go_left then
            for x = start_x, max_x do
                if x + 1 <= max_x then
                    break_blocking_blocks(x + 1, row)
                end
                while bot:pos().tile_x < x do
                    bot:walk(1, 0)
                    sleep_ms(CONFIG.PLANT_MOVE)
                end
                sleep_ms(300)
                process_tile(x, row)
            end
        else
            for x = max_x, start_x, -1 do
                if x - 1 >= start_x then
                    break_blocking_blocks(x - 1, row)
                end
                while bot:pos().tile_x > x do
                    bot:walk(-1, 0)
                    sleep_ms(CONFIG.PLANT_MOVE)
                end
                sleep_ms(300)
                process_tile(x, row)
            end
        end

        ::continue::
    end

    log_status(string.format(
        "✅ Selesai! Row: %d~%d | Harvest: %d | Plant: %d",
        row_min, row_max, harvested, planted
    ))
    isBusy = false
end

-- ============================================================
--                   PNB RANDOM WORLD MODE
-- ============================================================

local function reset_pnb_mode()
    isInPnbMode     = false
    pnbRandomWorld  = nil
    pnbCycleCount   = 0
    pnbNeedCollect  = false
    pnbJustRejoined = false
    log_status("🔄 PNB mode di-reset.")
end

local function do_pnb_in_random_world()
    isBusy = true

    -- Generate world random baru jika belum ada
    if not pnbRandomWorld then
        pnbRandomWorld = generate_random_world()
        pnbCycleCount  = 0
        log_status("🎲 World random PNB: " .. pnbRandomWorld)
    end

    isInPnbMode = true

    -- ============================================================
    --   INLINE REJOIN HELPER — dipakai di semua titik disconnect
    --   Langsung reconnect + warp ke pnbRandomWorld dari dalam fungsi
    --   tanpa bergantung ke STATE_CHANGED / handle_pnb_rejoin
    -- ============================================================
    local function pnb_ensure_connected(label)
        if bot:state() == "InWorld" then return true end

        log_status("⚠️ [" .. label .. "] Disconnect terdeteksi → auto rejoin ke " .. pnbRandomWorld .. "...")

        local maxTry = 10
        for attempt = 1, maxTry do
            local state = bot:state()
            if state == "InWorld" then
                log_status("✅ [" .. label .. "] Kembali online! (attempt " .. attempt .. ")")
                sleep_ms(1000)
                
                return true
            end

            log_status(string.format(
                "🔄 [%s] Reconnect attempt %d/%d (state: %s)...",
                label, attempt, maxTry, state
            ))

            if state == "Failed" or state == "Disconnected" then
                bot:connect()
                sleep_ms(2000)
            elseif state == "MenuIdle" then
                bot:warp(pnbRandomWorld)
                sleep_ms(CONFIG.PNB_REJOIN_DELAY)
            else
                -- Connecting / unknown state, tunggu dulu
                sleep_ms(2000)
            end
        end

        log_status("❌ [" .. label .. "] Gagal reconnect setelah " .. maxTry .. " attempt, abort PNB mode.")
        return false
    end

    -- ===== WARP AWAL KE WORLD RANDOM =====
    log_status("🚀 Warp ke PNB world: " .. pnbRandomWorld .. " (siklus " .. (pnbCycleCount + 1) .. "/" .. CONFIG.PNB_MAX_CYCLES .. ")")
    bot:warp(pnbRandomWorld)
    sleep_ms(CONFIG.PNB_REJOIN_DELAY)

    if not pnb_ensure_connected("WarpAwal") then
        reset_pnb_mode()
        bot:warp(CONFIG.FARM_WORLD)
        sleep_ms(4500)
        ensure_in_world(CONFIG.FARM_WORLD, "PNB-AbortReturnFarm")
        needCollect = true
        isBusy      = false
        return
    end

    sleep_ms(500)
    

    -- Simpan posisi awal di world random untuk PNB
    local pos  = bot:pos()
    pnbOriginX = pos.tile_x
    pnbOriginY = pos.tile_y

    -- ===================================================
    --   LOOP SIKLUS: PNB → Collect  (per siklus = 1x)
    -- ===================================================
    while pnbCycleCount < CONFIG.PNB_MAX_CYCLES do

        if not pnb_ensure_connected("AwalSiklus") then
            reset_pnb_mode()
            bot:warp(CONFIG.FARM_WORLD)
            sleep_ms(4500)
            ensure_in_world(CONFIG.FARM_WORLD, "PNB-AbortReturnFarm")
            needCollect = true
            isBusy      = false
            return
        end

        log_status(string.format(
            "🎯 PNB siklus %d/%d di world: %s",
            pnbCycleCount + 1, CONFIG.PNB_MAX_CYCLES, pnbRandomWorld
        ))

        -- ===== STEP 1: SB+HB per spot =====
        local spots = {}
        for _, spot in ipairs(CONFIG.PNB_SPOTS) do
            table.insert(spots, {
                x = pnbOriginX + spot.dx,
                y = pnbOriginY + spot.dy,
            })
        end

        for _, p in ipairs(spots) do

            if not pnb_ensure_connected("SebelumSpot") then
                reset_pnb_mode()
                bot:warp(CONFIG.FARM_WORLD)
                sleep_ms(4500)
                ensure_in_world(CONFIG.FARM_WORLD, "PNB-AbortReturnFarm")
                needCollect = true
                isBusy      = false
                return
            end

            for i = 1, CONFIG.PNB_COUNT_BLOCK do

                if bot:state() ~= "InWorld" then
                    log_status("⚠️ Disconnect saat SB/HB (iterasi " .. i .. "), rejoin...")
                    if not pnb_ensure_connected("SB-HB-iter" .. i) then
                        reset_pnb_mode()
                        bot:warp(CONFIG.FARM_WORLD)
                        sleep_ms(4500)
                        ensure_in_world(CONFIG.FARM_WORLD, "PNB-AbortReturnFarm")
                        needCollect = true
                        isBusy      = false
                        return
                    end
                end

                bot:send("SB", {
                    x         = p.x,
                    y         = p.y,
                    BlockType = CONFIG.TARGET_ID
                })
                for j = 1, CONFIG.PNB_HIT_COUNT do
                    bot:send("HB", { x = p.x, y = p.y })
                end
            end
        end

        sleep_ms(CONFIG.PNB_LOOP_DELAY)

        -- ===== STEP 2: COLLECT =====
        -- Collect selalu diulang dari awal jika disconnect atau find_path gagal
        -- pnbJustRejoined diabaikan di sini karena collect restart otomatis via nil
        pnbJustRejoined = false  -- reset flag, tidak dipakai di sini

        if not pnb_ensure_connected("SebelumCollect") then
            reset_pnb_mode()
            bot:warp(CONFIG.FARM_WORLD)
            sleep_ms(4500)
            ensure_in_world(CONFIG.FARM_WORLD, "PNB-AbortReturnFarm")
            needCollect = true
            isBusy      = false
            return
        end

        log_status("📦 Collect siklus ke-" .. (pnbCycleCount + 1) .. "...")

        local function run_collect()
            safe_find_path(pnbOriginX, pnbOriginY)
            sleep_ms(500)

            for _, spot in ipairs(CONFIG.PNB_SPOTS) do
                local tx = pnbOriginX + spot.dx
                local ty = pnbOriginY + spot.dy

                if bot:state() ~= "InWorld" then
                    if not pnb_ensure_connected("CollectMove") then
                        return false
                    end
                    log_status("🔄 Rejoin saat collect → ulang dari spot pertama...")
                    return nil
                end

                log_status("  → find_path ke (" .. tx .. ", " .. ty .. ")")

                local ok = pcall(function() bot:find_path(tx, ty) end)
                sleep_ms(500)
                if not ok then
                    log_status("⚠️ find_path gagal ke (" .. tx .. "," .. ty .. "), break block & retry...")
                    clear_tile_if_blocked(tx, ty)
                    sleep_ms(300)
                    local ok2 = pcall(function() bot:find_path(tx, ty) end)
                    sleep_ms(500)
                    if not ok2 then
                        log_status("⚠️ Masih gagal, ulang collect dari awal...")
                        return nil
                    end
                end

                sleep_ms(CONFIG.COLLECT_MOVE_DELAY)
            end

            log_status("🔙 Kembali ke origin (" .. pnbOriginX .. "," .. pnbOriginY .. ")")
            safe_find_path(pnbOriginX, pnbOriginY)
            sleep_ms(400)

            return true
        end

        while true do
            local result = run_collect()
            if result == true then
                break
            elseif result == false then
                reset_pnb_mode()
                bot:warp(CONFIG.FARM_WORLD)
                sleep_ms(4500)
                ensure_in_world(CONFIG.FARM_WORLD, "PNB-AbortReturnFarm")
                needCollect = true
                isBusy      = false
                return
            end
            -- nil → disconnect atau find_path gagal, ulang collect dari awal
            pnbJustRejoined = false
            sleep_ms(1000)
        end

        -- Siklus selesai
        pnbCycleCount   = pnbCycleCount + 1
        pnbNeedCollect  = false
        pnbJustRejoined = false

        log_status(string.format(
            "✅ Siklus %d/%d selesai di %s",
            pnbCycleCount, CONFIG.PNB_MAX_CYCLES, pnbRandomWorld
        ))

        -- Cek inventory
        local _, blockCount = get_inventory_count()
        log_status("📊 Block count setelah siklus: " .. blockCount .. " (threshold: " .. CONFIG.BLOCK_THRESHOLD .. ")")

        if blockCount < CONFIG.BLOCK_THRESHOLD then
            log_status("📉 Block sudah berkurang di bawah threshold, keluar PNB mode lebih awal.")
            break
        end

        if pnbCycleCount < CONFIG.PNB_MAX_CYCLES then
            log_status("🔁 Lanjut siklus berikutnya di world yang sama: " .. pnbRandomWorld)
            local pos2 = bot:pos()
            pnbOriginX = pos2.tile_x
            pnbOriginY = pos2.tile_y
        end

    end

    -- ===== SELESAI SEMUA SIKLUS (atau block habis) → KEMBALI KE FARM =====
    log_status(string.format(
        "🏁 PNB mode selesai (%d siklus) → Kembali ke farm world: %s",
        pnbCycleCount, CONFIG.FARM_WORLD
    ))

    reset_pnb_mode()

    bot:warp(CONFIG.FARM_WORLD)
    sleep_ms(4500)

    if bot:state() ~= "InWorld" then
        ensure_in_world(CONFIG.FARM_WORLD, "PNB-ReturnFarm")
    end

    needCollect = true
    isBusy      = false
end


-- ============================================================
--                         PLANT ROW
-- ============================================================

local function do_plant_row()
    isBusy = true

    local pos     = bot:pos()
    local row     = pos.tile_y
    local start_x = pos.tile_x + 2
    local w       = bot:get_world()
    local max_x   = w.width - 2

    log_status("🌱 Plant dari X=" .. start_x .. " → X=" .. max_x)

    for x = start_x, max_x do
        local ok = pcall(function() bot:find_path(x, row) end)
        if ok then
            -- Break block yang menghalangi sebelum plant
            break_blocking_blocks(x, row)

            local tile = bot:get_tile(x, row)
            if tile and tile.fg == 0 then
                bot:plant(x, row, CONFIG.TARGET_ID)
                sleep_ms(200)
            end
        end
    end

    log_status("✅ Plant selesai!")
    isBusy = false
end

-- ============================================================
--                       AUTO BAN
-- ============================================================

local function normalizeUsername(username)
    local cleaned = tostring(username or ""):gsub("[^%w]", "")
    return string.upper(cleaned)
end

local function isWhitelisted(username)
    return CONFIG.WHITELIST[normalizeUsername(username)] == true
end

local function buildPlayerList()
    local result = {}
    for _, player in ipairs(bot:get_players()) do
        result[player.user_id] = {
            username = player.username,
            user_id  = player.user_id,
        }
    end
    return result
end

local function do_auto_ban()
    if not CONFIG.AUTO_BAN_ENABLED then return end
    -- Hanya aktif di farm world, bukan di save world atau pnb world
    if isInSaveWorld then return end
    if isInPnbMode then return end

    local currentPlayers = buildPlayerList()

    for userId, player in pairs(currentPlayers) do
        if not knownPlayers[userId] then
            local username = player.username or "UNKNOWN"
            log_status("👤 Player join: " .. username .. " (ID: " .. userId .. ")")

            if isWhitelisted(username) then
                log_status("✅ WHITELIST OK → " .. username)
            else
                log_status("🚨 NON-WHITELIST → BAN: " .. username .. " (ID: " .. userId .. ")")
                bot:world_ban(userId)
                log_status("🔨 BANNED: " .. username)
            end
        end
    end

    knownPlayers = currentPlayers
end

-- ============================================================
--                    AUTO BAN THREAD
-- ============================================================

runThread(function()
    while true do
        if bot and bot:state() == "InWorld" then
            pcall(do_auto_ban)
        end
        sleep_ms(100)
    end
end)


